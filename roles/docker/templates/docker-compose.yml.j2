services:
  honcho-api:
    image: ghcr.io/plastic-labs/honcho:latest
    entrypoint: ["sh", "docker/entrypoint.sh"]
    depends_on:
      honcho-database:
        condition: service_healthy
      honcho-redis:
        condition: service_healthy
    ports:
      - "{{ honcho_api_port }}:8000"
    environment:
      - DB_CONNECTION_URI=postgresql+psycopg://{{ honcho_db_user }}:{{ honcho_db_password }}@honcho-database:5432/{{ honcho_db_name }}
      - CACHE_URL=redis://honcho-redis:6379/0?suppress=true
    env_file:
      - path: .env
        required: false
    restart: always

  honcho-deriver:
    image: ghcr.io/plastic-labs/honcho:latest
    entrypoint: ["python", "-m", "src.deriver"]
    depends_on:
      honcho-database:
        condition: service_healthy
      honcho-redis:
        condition: service_healthy
    environment:
      - DB_CONNECTION_URI=postgresql+psycopg://{{ honcho_db_user }}:{{ honcho_db_password }}@honcho-database:5432/{{ honcho_db_name }}
      - CACHE_URL=redis://honcho-redis:6379/0?suppress=true
      - METRICS_ENABLED=false
    env_file:
      - path: .env
        required: false
    restart: always

  honcho-database:
    image: pgvector/pgvector:pg15
    restart: always
    command: ["postgres", "-c", "max_connections=800"]
    environment:
      - POSTGRES_DB={{ honcho_db_name }}
      - POSTGRES_USER={{ honcho_db_user }}
      - POSTGRES_PASSWORD={{ honcho_db_password }}
      - POSTGRES_HOST_AUTH_METHOD=trust
      - PGDATA=/var/lib/postgresql/data/pgdata
    volumes:
      - honcho-pgdata:/var/lib/postgresql/data/
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U {{ honcho_db_user }} -d {{ honcho_db_name }}"]
      interval: 5s
      timeout: 5s
      retries: 5

  honcho-redis:
    image: redis:8.2
    restart: always
    volumes:
      - honcho-redis-data:/data
    healthcheck:
      test: ["CMD-SHELL", "redis-cli ping"]
      interval: 5s
      timeout: 5s
      retries: 5

volumes:
  honcho-pgdata:
  honcho-redis-data:
